# Local editor / agent settings
.claude/settings.local.json

# Secrets
.env
*.env.local

# Python bytecode
__pycache__/
*.py[cod]

# Runtime logs and databases
logs/
cloudflared-*.log

# OS/editor noise
.DS_Store
Thumbs.db
.venv/
# SQLite runtime artifacts — never commit
data/*.db-shm
data/*.db-wal

# Timestamped backups written by patch/retrain scripts
*.bak_*
*.backup_*
models/nn_backup_*/

# Generated site-RAG corpus (synced from the deployment-local portal)
docs/site_corpus.txt
kics-local/

# Local security-scan artifacts
bandit-local.json
ba*.json

# Local model backups (rollback snapshots) — kept out of git
models_old/
archive/models_backups/
