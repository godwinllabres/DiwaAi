# Local editor / agent settings
.claude/settings.local.json

# Secrets
.env
*.env.local

# Python bytecode
__pycache__/
*.py[cod]

# Runtime logs and databases
logs/
cloudflared-*.log

# OS/editor noise
.DS_Store
Thumbs.db
.venv/
# SQLite runtime artifacts — never commit
data/*.db-shm
data/*.db-wal

# Timestamped backups written by patch/retrain scripts
*.bak_*
*.backup_*
models/nn_backup_*/

# NOTE: docs/site_corpus.txt is deliberately TRACKED, like
# docs/citizens_charter_text.txt. It was ignored here until 2026-07-23, which
# meant CI built the image from a fresh clone that had no corpus, get_index()
# returned None, and the site tier was silently dead in every deployment —
# 0 of 382 production turns were ever "(site-grounded)". .dockerignore already
# un-ignores it (`!docs/site_corpus.txt`); that only works if git carries it.
kics-local/

# Local security-scan artifacts
bandit-local.json
ba*.json

# Local model backups (rollback snapshots) — kept out of git
models_old/
archive/models_backups/

# Joint slot-filling model artifacts and eval outputs — regenerable, and nothing
# at runtime loads them (the shadow integration was measured and not merged, see
# docs/SLOT_FILLING.md). Kept out of git so 2.3 MB of dead weight does not ride
# `COPY . .` into the deploy image. Rebuild with:
#   python scripts/build_slot_corpus.py && python training/train_joint_nlu.py
# Training is deterministic under the fixed seed, so the committed corpus plus
# these two commands reproduce the reported numbers exactly.
models/joint_*
models/eval_joint*.json
data/eval/slot_preds*.json
data/eval/slot_failures*.json
