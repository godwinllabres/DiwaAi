# Copy this file to .env and fill in your values.
# The .env file is gitignored — never commit real secrets.

# ----------------------------------------------------------------------
# Admin access
# ----------------------------------------------------------------------
# PIN for the admin endpoints (/admin/*, /ais_mcp_stats, /connectors_mcp_stats,
# and the runtime LLM toggle GET/POST /admin/llm). Sent as the X-Admin-Pin
# header. Leave unset to keep every admin endpoint disabled (503).
DASHBOARD_PIN=

# ----------------------------------------------------------------------
# Chat history / feedback store (api/logger.py)
# ----------------------------------------------------------------------
# Unset (default): SQLite at logs/chat_history.db — zero setup, fine for a
# single-process dev server.
# Set to a PostgreSQL DSN to move chat logs, feedback, and model provenance
# to Postgres (required for multi-worker deployments; see
# docs/POSTGRES_MIGRATION.md for the one-time data migration):
# DATABASE_URL=postgresql://sevi:sevi@localhost:5432/sevi

# ----------------------------------------------------------------------
# LLM fallback provider
# ----------------------------------------------------------------------
# Which LLM (if any) handles queries that NB and NN can't classify.
#   ollama          -> local model served by Ollama's native API (free, offline)
#   openai / localai-> any OpenAI-compatible server (LocalAI, vLLM, llama.cpp,
#                      LM Studio, or a hosted OpenAI endpoint)
#   claude          -> Anthropic Claude API (requires API key + credits, fast)
#   none            -> no LLM fallback; unknown queries get a static response
LLM_PROVIDER=ollama

# ----------------------------------------------------------------------
# Ollama config (used when LLM_PROVIDER=ollama)
# ----------------------------------------------------------------------
# Default Ollama server URL — change only if you run Ollama on another host.
OLLAMA_BASE_URL=http://localhost:11434

# Local model to use. Must be pulled first.
# Options (pull whichever you want):
#   ollama pull llama3.2:3b   - fast (~3x), good for demos (~2GB)
#   ollama pull llama3.1      - higher quality, slower on CPU (~4.9GB)
OLLAMA_MODEL=llama3.2:3b

# ----------------------------------------------------------------------
# OpenAI-compatible config (used when LLM_PROVIDER=openai or localai)
# ----------------------------------------------------------------------
# Base URL of the OpenAI-compatible API — MUST include the /v1 prefix.
#   LocalAI (compose service below):  http://localai:8080/v1
#   local LocalAI:                    http://localhost:8080/v1
# OPENAI_BASE_URL=http://localhost:8080/v1
# Model name as the server exposes it (LocalAI: the served id — for a GGUF
# installed by URI this is the .gguf filename, e.g. below).
# OPENAI_MODEL=Qwen2.5-3B-Instruct-Q4_K_M.gguf
# Optional API key — LocalAI usually needs none; set if your endpoint requires it.
# OPENAI_API_KEY=

# ----------------------------------------------------------------------
# Claude API config (used when LLM_PROVIDER=claude)
# ----------------------------------------------------------------------
# Get your API key from https://console.anthropic.com/settings/keys
# Leave blank if not using Claude.
ANTHROPIC_API_KEY=

# Claude model — haiku is fast/cheap, sonnet is higher quality.
CLAUDE_MODEL=claude-haiku-4-5

# ----------------------------------------------------------------------
# MCP bridges (AIS finance bridge: see api/ais_mcp.py docstring for its
# AIS_MCP_* vars; shared read-only connectors bridge below)
# ----------------------------------------------------------------------
# The diwa-connectors server (connectors_mcp/ package) hosts helpdesk ticket
# tracking + course-catalog tools. Start it with `diwa-connectors` (default
# 127.0.0.1:8766) and keep it on loopback — the MCP wire is unauthenticated.
CONNECTORS_MCP_URL=http://127.0.0.1:8766/sse
CONNECTORS_MCP_ENABLED=1
CONNECTORS_MCP_TIMEOUT_SECONDS=8.0
# Opt-in LLM router: when the regex router misses on a connectors-shaped
# message (e.g. Filipino/Taglish phrasing), an LLM extracts {tool, args}.
# Provider follows LLM_PROVIDER (Ollama preferred). Router model defaults to
# the small/fast one — routing is JSON extraction, not prose.
CONNECTORS_MCP_LLM_ROUTER=0
# CONNECTORS_MCP_OLLAMA_MODEL=llama3.2:3b
# CONNECTORS_MCP_LLM_MODEL=claude-haiku-4-5-20251001

# ----------------------------------------------------------------------
# AIS finance bridge (api/ais_mcp.py, api/auth_ais.py)
# ----------------------------------------------------------------------
# Diwa talks to the AIS MCP server over SSE; that server talks to the Frappe
# AIS bench. The bench serves the `accounting.localhost` Frappe SITE — the
# host is routed by the HTTP Host header, so server-side calls hit the IP and
# send Host: accounting.localhost:<port> (Python can't resolve *.localhost on
# Windows; browsers can). Standard dev port for this stack is now 8090.
AIS_MCP_URL=http://127.0.0.1:8765/sse
AIS_MCP_ENABLED=1
# Browser deep-links on DV cards (clickable DV -> Frappe Desk form):
AIS_DESK_URL=http://accounting.localhost:8090
# Server-side egress to Frappe (IP + Host header — the Windows *.localhost fix):
AIS_BASE_URL=http://127.0.0.1:8090
AIS_HOST_HEADER=accounting.localhost:8090
# OAuth client for the /auth/login pass-through (from tabOAuth Client where
# app_name = "CvSU AIS MCP"):
AIS_OAUTH_CLIENT_ID=
AIS_OAUTH_CLIENT_SECRET=
# Opt-in AIS LLM router (extracts {tool,args} when the regex router misses):
AIS_MCP_LLM_ROUTER=0

# ----------------------------------------------------------------------
# Safety / moderation (api/safety.py, docs/moderation_plan.md)
# ----------------------------------------------------------------------
# Opt-in LLM second opinion: catches PARAPHRASED self-harm/threats the
# lexicon can't ("I don't want to be here anymore"). An LLM is asked only when
# a conservative concern-cue prefilter matches, so most chats never pay it.
# Fail-safe: any LLM error just falls back to the lexicon verdict.
SAFETY_LLM_SECOND_OPINION=0
# SAFETY_LLM_MODEL=llama3.2:3b        # defaults to OLLAMA_MODEL / haiku

# ----------------------------------------------------------------------
# Citizens' Charter retrieval tier (document tier of the hybrid brain)
# ----------------------------------------------------------------------
# TF-IDF retrieval over docs/citizens_charter_text.txt. Grounds LLM answers
# in the charter (with page citations); when no LLM is available, strong
# matches are quoted verbatim instead of the static fallback.
CHARTER_RAG_ENABLED=1
# CHARTER_RAG_PATH=docs/citizens_charter_text.txt

# ----------------------------------------------------------------------
# Official-website retrieval tier (site tier of the hybrid brain)
# ----------------------------------------------------------------------
# TF-IDF retrieval over docs/site_corpus.txt — WordPress posts + pages with
# metadata, synced from the portal via POST /admin/site_corpus/sync (or
# api.site_rag.sync_corpus()). Grounds LLM answers in the official website
# (with title/URL citations); strong matches are quoted verbatim when no
# LLM is available.
SITE_RAG_ENABLED=1
# SITE_RAG_PATH=docs/site_corpus.txt
# Portal base URL the sync pulls from — REQUIRED for sync, set it in your
# local .env only (internal hosts must not be committed):
# SITE_CORPUS_URL=http://<portal-host>
# Public domain substituted into stored links/citations so internal hosts
# never reach users or the corpus file (default shown):
# SITE_PUBLIC_BASE_URL=https://cvsu.edu.ph

# ----------------------------------------------------------------------
# Per-intent source grounding (citations on curated intent replies)
# ----------------------------------------------------------------------
# The intent tiers (Naive Bayes / Neural Network / intent retrieval) serve
# curated answers with no provenance. This binds each intent to the official
# document that backs it (a Citizens' Charter page or an official-site URL),
# so those replies carry a "Source:" line and a structured `sources` list on
# the /chat envelope. Bindings live in data/intent_sources.json and are
# generated + verified offline — never computed at serve time:
#
#   python scripts/bind_intent_sources.py           # propose bindings
#   python scripts/bind_intent_sources.py --apply   # promote reviewed ones
#   python scripts/bind_intent_sources.py --check   # drift-check vs corpora
#
# Unbound intents simply get no citation, so partial coverage is safe.
INTENT_GROUNDING_ENABLED=1
# INTENT_GROUNDING_PATH=data/intent_sources.json

# ----------------------------------------------------------------------
# Intent-retrieval tier (soft pattern matching between the NN and the LLM)
# ----------------------------------------------------------------------
# Char-gram TF-IDF nearest-pattern match over the intents DB. Serves the
# curated response when the classifiers under-score a familiar phrasing.
INTENT_RETRIEVAL_ENABLED=1
# Serving floor for matches that agree with the NB tier's top guess
# (matches >= 0.80 serve unconditionally):
# INTENT_RETRIEVAL_MIN=0.60
