# Local server image — full hybrid stack (Naive Bayes + TensorFlow NN + LLM fallback).
# Built from the repo root: docker build -f deployment/Dockerfile.local .
# Unlike Dockerfile.render (512MB tier, no TensorFlow), this image includes
# tensorflow so the neural-network tier runs with the committed models/nn_*.

FROM python:3.11-slim

WORKDIR /app

# System deps (curl is used by the healthcheck)
RUN apt-get update && apt-get install -y \
    build-essential curl \
    && rm -rf /var/lib/apt/lists/*

# requirements_local.txt mirrors the environment that trained the committed
# models (sklearn 1.8 / numpy 2 / TF 2.21 + Keras 3) — the older pins in
# requirements.txt cannot unpickle/deserialize them.
COPY deployment/requirements_local.txt requirements.txt
RUN pip install --no-cache-dir -r requirements.txt

# Download NLTK data (both punkt and punkt_tab for compatibility across NLTK versions).
# NLTK_DATA points at a world-readable shared dir — without it the download
# (running as root at build time) lands in /root/nltk_data, unreadable by the
# runtime user, forcing a network re-download at every container creation.
# The mkdir must come first: nltk.download() only targets $NLTK_DATA when the
# directory already exists. wordnet/omw ship zipped and their index never
# unzips them, but nltk.data.find('corpora/wordnet') — which
# api/hybrid_chatbot.py calls at import — only resolves the unzipped
# directory, so extract them here.
ENV NLTK_DATA=/usr/local/share/nltk_data
RUN mkdir -p "$NLTK_DATA" \
    && python -c "import nltk; nltk.download('punkt'); nltk.download('punkt_tab'); nltk.download('wordnet'); nltk.download('omw-1.4')" \
    && python -m zipfile -e "$NLTK_DATA/corpora/wordnet.zip" "$NLTK_DATA/corpora/" \
    && python -m zipfile -e "$NLTK_DATA/corpora/omw-1.4.zip" "$NLTK_DATA/corpora/"

# Copy application (see .dockerignore — excludes .env, logs/, backups, test artifacts)
COPY . .

# Run as a non-root user. The app writes to /app/data (SQLite intents cache)
# and /app/logs at runtime, so hand ownership to the runtime user. logs/ is
# .dockerignore'd so COPY never creates it — mkdir it here, otherwise the
# compose named volume mounted at /app/logs is seeded root-owned and appuser
# can't write to it.
# data.seed is a snapshot of data/ taken outside the mount point. A named
# volume at /app/data seeds from the image only when Docker first creates it,
# so without this a `docker compose pull` ships new code over permanently
# stale intents. The entrypoint diffs .seed_version and refreshes repo-owned
# files on upgrade.
RUN cp -a /app/data /app/data.seed \
    && find /app/data.seed -type f -exec sha256sum {} + \
       | sort | sha256sum | cut -d' ' -f1 \
       > /app/data.seed/.seed_version \
    && mkdir -p /app/data /app/logs \
    && useradd --create-home --uid 10001 appuser \
    && chown -R appuser:appuser /app \
    && chmod +x /app/deployment/docker-entrypoint.sh
USER appuser

EXPOSE 8000

HEALTHCHECK --interval=30s --timeout=10s --start-period=30s --retries=3 \
    CMD curl -fsS http://localhost:8000/health || exit 1

# The entrypoint refreshes repo-owned files in the /app/data volume, then
# execs the CMD — so an image upgrade can no longer leave stale intents behind.
# Baked so the image reports its own identity at /health even when compose
# does not set SEVI_VERSION (a bare `docker run`, or a server whose compose
# file predates the variable). compose's environment: still wins at runtime.
ARG SEVI_VERSION=dev
ARG SEVI_BUILD=""
ENV SEVI_VERSION=${SEVI_VERSION} \
    SEVI_BUILD=${SEVI_BUILD}

ENTRYPOINT ["/app/deployment/docker-entrypoint.sh"]

# api.app:app is the server SeviWeb talks to (auth, map, logs, feedback, admin).
# Keep --workers 1: rate limiting, PIN lockout, and conversation state are
# in-memory per-process.
CMD ["uvicorn", "api.app:app", "--host", "0.0.0.0", "--port", "8000", "--workers", "1"]
