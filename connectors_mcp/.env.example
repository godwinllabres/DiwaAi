# diwa-connectors — shared read-only MCP tool server.
# A tool group is ACTIVE only when its BASE_URL is set (and its _ENABLED flag isn't 0).
# Unset a URL or set the flag to 0 and that group's tools vanish from the menu
# without affecting any other group.

# --- courses catalog (Laravel `courses` app; read endpoints under /api) ---
# NOTE: confirm this catalog is still authoritative (curriculum ownership is
# moving to registrar-cvsu) and that its write endpoints are closed upstream
# before pointing Diwa at production.
COURSES_BASE_URL=
CONNECTORS_COURSES_ENABLED=1

# --- ORPS / ICT Helpdesk ticket tracking (Frappe site hosting ticketing_platform) ---
ORPS_BASE_URL=
CONNECTORS_ORPS_ENABLED=1

# --- DTS document tracking (Frappe site hosting the dts app) ---
# Wraps the guest dts.api.search_document_movement lookup ("where is my document?").
DTS_BASE_URL=
CONNECTORS_DTS_ENABLED=1

# Hard ceiling per upstream call, in seconds. Matches Diwa's own per-tool
# ceiling (AIS_MCP_TIMEOUT_SECONDS) so a slow system never hangs the chat.
CONNECTORS_TIMEOUT_SECONDS=8.0

CONNECTORS_LOG_LEVEL=INFO
